---
// Base layout for every page. Renders the full HTML shell, the
// site-wide JSON-LD (Organization + WebSite), the per-page Head, and
// the Header / Footer.
//
// Pages should import this and pass their SEO frontmatter through.

import "@/styles/global.css";
import BaseHead from "@/components/BaseHead.astro";
import JsonLd from "@/components/JsonLd.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import { organizationSchema, websiteSchema } from "@/data/schemas";
import { SITE, type Page } from "@/data/seo";

interface Props extends Page {
  /** Optional extra JSON-LD documents specific to the page. */
  schemas?: Record<string, unknown>[];
}

const { title, description, path, ogImage, keywords, schemas = [] } = Astro.props;

const sitewideSchemas = [organizationSchema(), websiteSchema(), ...schemas];
---
<!doctype html>
<html lang={SITE.htmlLang}>
  <head>
    <BaseHead {title} {description} {path} {ogImage} {keywords} />
    <JsonLd data={sitewideSchemas} />
  </head>
  <body class="min-h-screen flex flex-col">
    <a href="#main"
       class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded-md focus:bg-primary focus:px-4 focus:py-2 focus:text-primary-foreground">
      Skip to content
    </a>
    <Header />
    <div class="alpha-banner" role="status" aria-label="Alpha release notice">
      <div class="mx-auto flex max-w-6xl items-center justify-center gap-3 px-6 py-2.5 text-center text-xs sm:text-sm">
        <span class="inline-flex size-5 shrink-0 items-center justify-center rounded-full border border-warning/40 bg-warning/15 font-bold text-warning">!</span>
        <span class="text-foreground/90">
          <strong class="font-semibold text-warning">Alpha release.</strong>
          Marauder is in early alpha. Most plugins are structurally complete but
          have not been validated against live services yet — expect rough edges.
          <a href="/trackers" class="underline decoration-warning/50 underline-offset-4 hover:decoration-warning">See plugin status →</a>
        </span>
      </div>
    </div>
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
