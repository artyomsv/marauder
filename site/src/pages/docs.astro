---
import Page from "@/layouts/Page.astro";
import { SITE } from "@/data/seo";
import { breadcrumbSchema } from "@/data/schemas";

const seo = {
  title: "Documentation — PRD, plugin guide, OIDC, migration",
  description:
    "Marauder's full documentation set: vision, competitors, PRD, roadmap, plugin development guide, Keycloak / OIDC walkthrough, Torznab / Newznab guide, end-to-end test reproducer, monitorrent migration guide, and CI documentation.",
  path: "/docs",
  keywords: [
    "marauder docs",
    "marauder plugin development",
    "self-hosted torrent monitor docs",
  ],
};

const schemas = [
  breadcrumbSchema([
    { name: "Marauder", path: "/" },
    { name: "Documentation", path: "/docs" },
  ]),
];

const sections = [
  {
    title: "Project context",
    items: [
      { name: "Vision",      path: "docs/VISION.md",      desc: "Why Marauder exists, who it's for, what it's not." },
      { name: "Competitors", path: "docs/COMPETITORS.md", desc: "Marauder's place next to Sonarr, Radarr, Prowlarr, Jackett, FlexGet, monitorrent." },
      { name: "PRD",         path: "docs/PRD.md",         desc: "Full product requirements: personas, user stories, data model, API surface, security model, deployment topology." },
      { name: "Roadmap",     path: "docs/ROADMAP.md",     desc: "Milestone-by-milestone status with v1.0 ticked." },
      { name: "Changelog",   path: "CHANGELOG.md",        desc: "Keep-a-Changelog formatted history of every release." },
    ],
  },
  {
    title: "How-to guides",
    items: [
      { name: "End-to-end magnet test",     path: "docs/test-e2e-magnet.md",          desc: "Step-by-step reproducer for the magnet → qBittorrent walkthrough using the dev compose overlay." },
      { name: "Keycloak / OIDC",            path: "docs/oidc.md",                     desc: "How to enable OpenID Connect sign-in via the bundled Keycloak realm or any OIDC provider." },
      { name: "Torznab / Newznab",          path: "docs/torznab-newznab.md",          desc: "Connect Jackett, Prowlarr, NZBHydra2, NZBGeek, and any indexer that speaks Torznab or Newznab." },
      { name: "Migrate from monitorrent",   path: "docs/migrating-from-monitorrent.md", desc: "Step-by-step migration guide for users coming from werwolfby/monitorrent." },
    ],
  },
  {
    title: "Developer guides",
    items: [
      { name: "Contributing",          path: "CONTRIBUTING.md",            desc: "Local dev with Docker, test running, PR checklist, conventions." },
      { name: "Plugin development",    path: "docs/plugin-development.md", desc: "How to write a tracker, client, or notifier plugin in under 200 lines of Go." },
      { name: "CI / CD pipeline",      path: "docs/ci.md",                 desc: "Per-workflow documentation: ci.yml, docker.yml, e2e.yml, release.yml, codeql.yml + Dependabot." },
      { name: "Site deploy",           path: "docs/site-deploy.md",        desc: "How marauder.cc itself is built (Astro), tested (actionlint), and deployed (GitHub Pages with custom domain)." },
    ],
  },
];
---
<Page {...seo} schemas={schemas}>
  <article class="mx-auto max-w-4xl px-6 py-16">
    <nav aria-label="Breadcrumb" class="mb-4 text-sm text-muted-foreground">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-foreground">Marauder</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-foreground">Documentation</li>
      </ol>
    </nav>

    <header class="mb-12">
      <p class="mb-2 text-xs font-mono uppercase tracking-wider text-primary">technical documentation</p>
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">Documentation</h1>
      <p class="mt-4 max-w-3xl text-lg text-muted-foreground">
        Every document Marauder ships lives in the GitHub repo, in plain
        Markdown. The links below open the canonical source — pull requests
        welcome on any of them.
      </p>
    </header>

    <div class="space-y-12">
      {sections.map((section) => (
        <section aria-labelledby={section.title.toLowerCase().replace(/\W+/g, "-")}>
          <h2 id={section.title.toLowerCase().replace(/\W+/g, "-")} class="mb-5 text-2xl font-semibold tracking-tight">
            {section.title}
          </h2>
          <ul class="grid gap-4 sm:grid-cols-2">
            {section.items.map((item) => (
              <li>
                <a href={`${SITE.github}/blob/main/${item.path}`} rel="noopener external"
                   class="glass-card block h-full rounded-xl p-5 transition-colors hover:border-primary/60">
                  <h3 class="font-semibold text-foreground">{item.name}</h3>
                  <p class="mt-1 text-sm text-muted-foreground">{item.desc}</p>
                  <p class="mt-2 font-mono text-xs text-muted-foreground">{item.path}</p>
                </a>
              </li>
            ))}
          </ul>
        </section>
      ))}
    </div>

    <section class="mt-16 glass-card rounded-2xl p-8" aria-labelledby="repo-heading">
      <h2 id="repo-heading" class="text-xl font-semibold tracking-tight">Reading the source</h2>
      <p class="mt-3 text-muted-foreground">
        Most of what you'll want is in two folders. The Go backend lives at
        <a href={`${SITE.github}/tree/main/backend`} rel="noopener external" class="text-foreground underline decoration-primary/60 underline-offset-4 hover:decoration-primary">backend/</a>
        and the React frontend at
        <a href={`${SITE.github}/tree/main/frontend`} rel="noopener external" class="text-foreground underline decoration-primary/60 underline-offset-4 hover:decoration-primary">frontend/</a>.
        Plugins are under
        <a href={`${SITE.github}/tree/main/backend/internal/plugins`} rel="noopener external" class="text-foreground underline decoration-primary/60 underline-offset-4 hover:decoration-primary">backend/internal/plugins/</a> —
        each tracker, client, and notifier is one self-contained Go file plus its tests.
      </p>
    </section>
  </article>
</Page>
