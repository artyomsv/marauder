---
import Page from "@/layouts/Page.astro";

const seo = {
  title: "Page not found",
  description: "The page you are looking for does not exist on marauder.cc.",
  path: "/404",
};
---
<Page {...seo}>
  <section class="mx-auto flex max-w-2xl flex-col items-center justify-center px-6 py-32 text-center">
    <p class="font-mono text-7xl font-bold text-primary sm:text-8xl">404</p>
    <h1 class="mt-6 text-3xl font-bold tracking-tight sm:text-4xl">
      That page wandered off.
    </h1>
    <p class="mt-4 max-w-md text-muted-foreground">
      The URL you tried doesn't exist on marauder.cc. Use one of the links
      below to get back to somewhere useful.
    </p>
    <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
      <a href="/" class="btn-primary">Home</a>
      <a href="/install" class="btn-outline">Install guide</a>
      <a href="/docs" class="btn-outline">Documentation</a>
    </div>
  </section>
</Page>
