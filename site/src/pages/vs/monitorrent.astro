---
import Page from "@/layouts/Page.astro";
import { breadcrumbSchema } from "@/data/schemas";

const seo = {
  title: "Marauder vs monitorrent — the modern successor",
  description:
    "Marauder is a ground-up rewrite of werwolfby/monitorrent in Go and React. The 12 trackers, 5 clients, 4 notifiers monitorrent shipped — plus Torznab, Newznab, OIDC, Cloudflare bypass, audit log, Prometheus metrics, and a UI from this decade.",
  path: "/vs/monitorrent",
  keywords: [
    "monitorrent alternative",
    "monitorrent replacement",
    "monitorrent fork",
    "monitorrent broken",
    "marauder vs monitorrent",
  ],
};

const schemas = [
  breadcrumbSchema([
    { name: "Marauder",          path: "/" },
    { name: "Compare",           path: "/" },
    { name: "vs monitorrent",    path: "/vs/monitorrent" },
  ]),
];

const matrix = [
  { feature: "RuTracker plugin",                   monitorrent: "yes (broken since 2024)", marauder: "yes" },
  { feature: "LostFilm plugin",                    monitorrent: "yes (broken since 2024)", marauder: "yes" },
  { feature: "NNM-Club plugin",                    monitorrent: "yes (Cloudflare broken)", marauder: "yes (with cfsolver sidecar)" },
  { feature: "Kinozal, Anidub, Anilibria, etc.",   monitorrent: "yes",                     marauder: "yes (12 forum trackers)" },
  { feature: "Torznab indexers",                   monitorrent: "no",                      marauder: "yes" },
  { feature: "Newznab indexers",                   monitorrent: "no",                      marauder: "yes" },
  { feature: "qBittorrent (modern v2 API)",        monitorrent: "broken on qBit 4.5+",     marauder: "yes (E2E validated)" },
  { feature: "Transmission, Deluge, µTorrent",     monitorrent: "yes",                     marauder: "yes" },
  { feature: "OIDC sign-in (Keycloak / Authentik)",monitorrent: "no",                      marauder: "yes" },
  { feature: "Multi-user with isolation",          monitorrent: "no (one shared admin)",   marauder: "yes" },
  { feature: "Audit log",                          monitorrent: "no",                      marauder: "yes" },
  { feature: "Prometheus metrics",                 monitorrent: "no",                      marauder: "yes" },
  { feature: "Argon2id passwords",                 monitorrent: "no (bcrypt at best)",     marauder: "yes" },
  { feature: "AES-256-GCM secrets at rest",        monitorrent: "no",                      marauder: "yes" },
  { feature: "Memory footprint (200 topics)",      monitorrent: "1+ GB, leaks",            marauder: "<150 MB, stable" },
  { feature: "Last release",                       monitorrent: "v1.4.0 (July 2023)",      marauder: "v1.0.0 (April 2026)" },
  { feature: "Frontend stack",                     monitorrent: "Aurelia (2019-era)",      marauder: "React 19 + Vite 8 + Tailwind 4 + shadcn/ui" },
  { feature: "License",                            monitorrent: "MIT",                     marauder: "MIT" },
];
---
<Page {...seo} schemas={schemas}>
  <article class="mx-auto max-w-4xl px-6 py-16">
    <nav aria-label="Breadcrumb" class="mb-4 text-sm text-muted-foreground">
      <ol class="flex items-center gap-2">
        <li><a href="/" class="hover:text-foreground">Marauder</a></li>
        <li aria-hidden="true">›</li>
        <li class="text-foreground">vs monitorrent</li>
      </ol>
    </nav>

    <header class="mb-12">
      <p class="mb-2 text-xs font-mono uppercase tracking-wider text-primary">comparison</p>
      <h1 class="text-4xl font-bold tracking-tight sm:text-5xl">
        Marauder vs monitorrent
      </h1>
      <p class="mt-4 text-lg text-muted-foreground">
        Marauder is a ground-up rewrite of <a href="https://github.com/werwolfby/monitorrent" rel="noopener external" class="text-foreground underline decoration-primary/60 underline-offset-4 hover:decoration-primary">werwolfby/monitorrent</a>
        in Go and React. monitorrent was the right product for years; the
        codebase has aged out and the maintainer has moved on. Marauder picks
        up where it left off.
      </p>
    </header>

    <section class="mb-12" aria-labelledby="status">
      <div class="glass-card rounded-2xl p-8">
        <h2 id="status" class="text-xl font-semibold tracking-tight">The state of monitorrent in 2026</h2>
        <p class="mt-3 text-muted-foreground">
          Since mid-2024, monitorrent has been functionally abandoned. The
          last release (1.4.0) was July 2023. Since then:
        </p>
        <ul class="mt-3 space-y-2 text-muted-foreground">
          <li>• <strong class="text-foreground">LostFilm</strong> stopped updating for most users (issues #415, #412, #411, #403)</li>
          <li>• <strong class="text-foreground">RuTracker</strong> updates began silently failing (#399)</li>
          <li>• <strong class="text-foreground">NNM-Club</strong> is now wrapped in Cloudflare; the built-in bypass is outdated (#407)</li>
          <li>• <strong class="text-foreground">qBittorrent ≥ 4.5</strong> introduced a new Web API shape that monitorrent does not speak (#402)</li>
          <li>• The container <strong class="text-foreground">leaks memory and crashes</strong> after a few hours (#393, #397)</li>
          <li>• <strong class="text-foreground">Proxy + Cloudflare cannot coexist</strong> (#363, #401)</li>
          <li>• The Python 2/3 codebase has <strong class="text-foreground">Unicode issues with Cyrillic paths</strong>, marked <em>wontfix</em> due to library constraints</li>
        </ul>
        <p class="mt-4 text-muted-foreground">
          The product is the right shape — Marauder doesn't reinvent it.
          What it does is rebuild the same idea on a foundation that's
          maintainable in 2026: Go for the backend, React 19 for the
          frontend, PostgreSQL 18 for state, modern crypto, OIDC,
          observability built in.
        </p>
      </div>
    </section>

    <section class="mb-12" aria-labelledby="matrix">
      <h2 id="matrix" class="mb-4 text-2xl font-semibold tracking-tight">Side-by-side</h2>
      <div class="overflow-x-auto rounded-xl border border-border/60">
        <table class="w-full text-sm">
          <thead class="bg-muted/40 text-xs uppercase tracking-wider text-muted-foreground">
            <tr>
              <th scope="col" class="px-4 py-3 text-left">Feature</th>
              <th scope="col" class="px-4 py-3 text-left">monitorrent</th>
              <th scope="col" class="px-4 py-3 text-left">Marauder</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border/60">
            {matrix.map((row) => (
              <tr class="hover:bg-muted/20">
                <td class="px-4 py-3 font-medium text-foreground">{row.feature}</td>
                <td class="px-4 py-3 text-muted-foreground">{row.monitorrent}</td>
                <td class="px-4 py-3 text-muted-foreground">{row.marauder}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>

    <section class="mb-12" aria-labelledby="migrate">
      <h2 id="migrate" class="mb-4 text-2xl font-semibold tracking-tight">Migrating</h2>
      <p class="text-muted-foreground">
        There is no automated importer in v1.0 — you re-add your topics in
        Marauder by pasting the same URLs. The good news is that the URLs
        themselves are unchanged: a RuTracker viewtopic.php link works in
        Marauder exactly the way it did in monitorrent.
      </p>
      <p class="mt-3 text-muted-foreground">
        Full step-by-step migration guide:
        <a href="https://github.com/artyomsv/marauder/blob/main/docs/migrating-from-monitorrent.md" rel="noopener external" class="text-foreground underline decoration-primary/60 underline-offset-4 hover:decoration-primary">docs/migrating-from-monitorrent.md</a>
      </p>
    </section>

    <section class="glass-card rounded-2xl p-8 text-center" aria-labelledby="cta">
      <h2 id="cta" class="text-2xl font-semibold tracking-tight">Move off monitorrent tonight</h2>
      <p class="mt-3 text-muted-foreground">Same trackers. Modern stack. Memory under control.</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a href="/install" class="btn-primary">Install Marauder</a>
        <a href="https://github.com/artyomsv/marauder/blob/main/docs/migrating-from-monitorrent.md" rel="noopener external" class="btn-outline">Migration guide</a>
      </div>
    </section>
  </article>
</Page>
