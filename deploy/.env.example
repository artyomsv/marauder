# --------------------------------------------------------------------
# Marauder — environment variables
# --------------------------------------------------------------------
# Copy this file to `.env` and fill in the values before running
# `docker compose up -d`.
# --------------------------------------------------------------------

# --- CRITICAL SECRETS -----------------------------------------------
# A 32-byte AES-256 master key, base64-encoded. Generate with:
#   openssl rand -base64 32
# ***LOSING THIS KEY WILL MAKE ALL STORED CREDENTIALS UNRECOVERABLE.***
MARAUDER_MASTER_KEY=CHANGE_ME_BASE64_32_BYTES

# Bearer token required to scrape /metrics. Leave empty to disable the
# endpoint entirely. Generate with:
#   openssl rand -hex 32
MARAUDER_METRICS_TOKEN=

# --- Initial admin bootstrap ----------------------------------------
# On first start, Marauder creates this user if the users table is
# empty. After first login, change the password via the UI and then
# clear both variables to prevent accidental re-use.
MARAUDER_ADMIN_INITIAL_USERNAME=admin
MARAUDER_ADMIN_INITIAL_PASSWORD=pleasechangeme

# --- Database -------------------------------------------------------
POSTGRES_DB=marauder
POSTGRES_USER=marauder
POSTGRES_PASSWORD=marauder
MARAUDER_DB_URL=postgres://marauder:marauder@db:5432/marauder?sslmode=disable

# --- Server ---------------------------------------------------------
MARAUDER_HTTP_ADDR=:8679
MARAUDER_PUBLIC_BASE_URL=http://localhost:6688
MARAUDER_LOG_LEVEL=info
MARAUDER_LOG_JSON=true
MARAUDER_CORS_ORIGINS=http://localhost:6688,http://localhost:5174

# --- JWT / sessions -------------------------------------------------
MARAUDER_JWT_ISSUER=https://marauder.cc
MARAUDER_JWT_AUDIENCE=marauder-api
MARAUDER_ACCESS_TOKEN_TTL=15m
MARAUDER_REFRESH_TOKEN_TTL=720h

# --- Scheduler ------------------------------------------------------
MARAUDER_SCHEDULER_ENABLED=true
MARAUDER_SCHEDULER_TICK=1m
MARAUDER_SCHEDULER_WORKERS=8
MARAUDER_DEFAULT_CHECK_INTERVAL=15m
MARAUDER_CHECK_MAX_BACKOFF=6h
MARAUDER_TRACKER_HTTP_TIMEOUT=30s

# --- OIDC (optional) ------------------------------------------------
# Set MARAUDER_OIDC_ENABLED=true and fill the four variables below to
# allow login via Keycloak, Authentik, Auth0, or any OIDC provider.
MARAUDER_OIDC_ENABLED=false
MARAUDER_OIDC_ISSUER=https://keycloak.example.com/realms/marauder
MARAUDER_OIDC_CLIENT_ID=marauder
MARAUDER_OIDC_CLIENT_SECRET=
MARAUDER_OIDC_REDIRECT_URL=http://localhost:6688/api/v1/auth/oidc/callback
MARAUDER_OIDC_SCOPES=openid,profile,email

# --- Cloudflare solver sidecar (optional, v0.3) ---------------------
MARAUDER_CFSOLVER_ENABLED=false
MARAUDER_CFSOLVER_URL=http://cfsolver:9244
