# Default: text files normalized to LF
* text=auto eol=lf

# Explicit text files
*.md          text eol=lf
*.go          text eol=lf
*.sql         text eol=lf
*.ts          text eol=lf
*.tsx         text eol=lf
*.js          text eol=lf
*.jsx         text eol=lf
*.json        text eol=lf
*.yml         text eol=lf
*.yaml        text eol=lf
*.sh          text eol=lf
*.env.example text eol=lf
Dockerfile    text eol=lf
Makefile      text eol=lf

# Windows-only scripts stay CRLF
*.bat         text eol=crlf
*.cmd         text eol=crlf
*.ps1         text eol=crlf

# Binaries
*.png         binary
*.jpg         binary
*.jpeg        binary
*.gif         binary
*.ico         binary
*.woff        binary
*.woff2       binary
